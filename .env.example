# Backend
FLASK_ENV=development
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-local-dev
MAX_UPLOAD_BYTES=10485760
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5000,http://localhost:5000

# Backend -> ML service
ML_API_URL=http://127.0.0.1:5001/analyze-report
ML_SYMPTOM_API_URL=http://127.0.0.1:5001/analyze-symptoms

# Flutter
API_BASE_URL=http://127.0.0.1:5000
MAPS_RUNTIME_KEY=replace-with-platform-secret-at-build-time

# Docker compose overrides
COMPOSE_PROJECT_NAME=healthcare_diagnostics
